{
  "name": "vtk-workbench",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:full": "npm run build-wasm:release && next build",
    "build:standalone": "npm run build-wasm:release && next build && next export",
    "start": "next start",
    "build-wasm:debug": "emcmake cmake -GNinja -S. -Bwebassembly/build -DCMAKE_BUILD_TYPE=Debug -DVTK_DIR=webassembly/dependencies/VTK/Debug/lib/cmake/vtk && cmake --build webassembly/build --target install",
    "build-wasm:release": "emcmake cmake -GNinja -S. -Bwebassembly/build -DCMAKE_BUILD_TYPE=Release -DVTK_DIR=webassembly/dependencies/VTK/Release/lib/cmake/vtk && cmake --build webassembly/build --target install",
    "build:docker": "docker build -t vtk-workbench .",
    "build:production": "npm run clean && npm run build",
    "clean": "npm run rm-build && npm run rm-wasm && if exist .next rmdir /s /q .next",
    "rm-build": "if exist webassembly\\build rmdir /s /q webassembly\\build",
    "rm-wasm": "if exist public\\wasm\\* del /f /q public\\wasm\\*",
    "health": "echo 'OK'",
    "check:phase12:architecture": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase12_architecture_seal.ps1",
    "check:phase18:ui-evidence": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_ui_regression_evidence.ps1",
    "check:phase18:facade-include-zero": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_facade_include_zero.ps1",
    "check:phase18:atoms-instance-zero": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_atoms_instance_zero.ps1",
    "check:phase18:legacy-singleton-zero": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_legacy_singleton_zero.ps1",
    "check:phase18:unused-asset-cleanup": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_unused_asset_cleanup.ps1",
    "check:phase18:doc-contract-full": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_doc_contract_full.ps1",
    "check:phase18:final-closure": "powershell -ExecutionPolicy Bypass -File scripts/refactoring/check_phase18_final_closure.ps1",
    "test:cpp": "cmd /c \"..\\emsdk\\emsdk_env.bat && emcmake cmake --fresh -S webassembly/tests -B webassembly/tests/build-em -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_CROSSCOMPILING_EMULATOR=node && cmake --build webassembly/tests/build-em --config Release && ctest --test-dir webassembly/tests/build-em --output-on-failure -C Release\"",
    "test:smoke": "playwright test",
    "test:phase6": "npm run check:phase12:architecture && npm run test:cpp && npm run test:smoke",
    "test:phase18": "cmd /c \"..\\emsdk\\emsdk_env.bat && npm.cmd run check:phase18:final-closure && npm.cmd run build-wasm:release && npm.cmd run test:cpp && npm.cmd run test:smoke\"",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@playwright/test": "^1.55.0",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "next": "^15.1.7",
    "puppeteer": "^24.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/swc-win32-x64-msvc": "^15.1.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
